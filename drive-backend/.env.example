# ============================================
#  DRIVE BACKEND — Environment Variables
#  Copy this to .env and fill in your values.
# ============================================

# Port for the Express server
PORT=4000

# Google Drive API Key (for reading public/shared folders)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# Google Service Account credentials (for uploading files)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Google Drive Folder IDs (share these folders with the service account email)
PHOTO_FOLDER_ID=
VIDEO_FOLDER_ID=

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Upload password (REQUIRED — uploads are blocked if not set)
UPLOAD_PASSWORD=
